{
  "manifest_version": 3,
  "name": "TransWord",
  "version": "1.2",
  "description": "Double-click any word to translate. Press Ctrl to hear it. Bookmark and export words via the toolbar.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://api.mymemory.translated.net/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["popup.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "toolbar.html",
    "default_title": "Translation Settings & Export"
  }
}
